// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  BUYER
  SELLER
  ADMIN
}

enum OrderStatus {
  CART
  AWAITING_PAYMENT
  PAID
  DISPUTED
  CANCELLED 
}

enum FulfillmentStatus {
  AWAITING_DROPOFF
  DROPPED_OFF
  COLLECTED
  CANCELLED
  DISPUTED
}

enum ListingStatus {
  DRAFT
  ACTIVE
  SOLDOUT
  ARCHIVED
  FLAGGED
}

enum ProductCondition {
  NEW
  USED_LIKE_NEW
  USED_GOOD
  USED_FAIR
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ModerationActionType {
  APPROVE
  REJECT
  SUSPEND
  FLAG
}

enum ListingCategory {
  FASHION
  BEAUTY
  FOOD
  CREATIVE
  TECH
  SERVICES
  OTHERS
}

model User {
  id            String      @id @default(uuid())
  email         String      @unique
  password      String?     
  googleId      String?     @unique
  firstName     String
  lastName      String
  role          UserRole
  trustScore     Float         @default(0)
  verificationStatus VerificationStatus @default(UNVERIFIED)
  isActive      Boolean     @default(true)
  isSuspended     Boolean     @default(false)

  institutionId  String?
  institution    Institution?   @relation(fields: [institutionId], references: [id])

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  listings      Listing[]   @relation("SellerListings")
  orders        Order[]     @relation("BuyerOrders")
  wishlist      Wishlist[]
  reviewsGiven   Review[]    @relation("Reviewer")
  reviewsReceived Review[]    @relation("Reviewee")
  verificationRequests VerificationRequest[]
  moderationActions ModerationAction[]
}

model Institution {
  id            String      @id @default(uuid())
  name          String      @unique
  domain        String?
  createdAt     DateTime    @default(now())

  users         User[]
  listings      Listing[]
}

model Listing {
  id            String      @id @default(uuid())
  title         String      
  description   String
  price         Decimal     @db.Decimal(10,2)
  quantity      Int
  category      ListingCategory
  status        ListingStatus @default(DRAFT)
  condition     ProductCondition
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  isDeleted     Boolean     @default(false)
  isPromoted     Boolean     @default(false)
  isFlagged     Boolean     @default(false)

  sellerId      String
  seller        User        @relation("SellerListings", fields: [sellerId], references: [id])

  institutionId  String?
  institution    Institution? @relation(fields: [institutionId], references: [id])

  images        ListingImage[]
  orderItems    OrderItem[]
  wishlistedBy  Wishlist[]
  reviews       Review[]
  moderationLogs  ModerationAction[]

  @@index([sellerId, status, institutionId])
}

model ListingImage {
  id            String      @id @default(uuid())
  url           String
  listingId     String
  listing       Listing     @relation(fields: [listingId], references: [id])
}

model Order {
  id            String      @id @default(uuid())
  status        OrderStatus @default(CART)
  fulfillmentStatus FulfillmentStatus? // Only applicable when status is PAID
  totalAmount   Decimal     @db.Decimal(10,2)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  buyerId       String
  buyer         User        @relation("BuyerOrders", fields: [buyerId], references: [id])

  items         OrderItem[]
  payment       Payment?
  review        Review?

  @@index([buyerId, status])
}

model OrderItem {
  id            String      @id @default(uuid())
  quantity      Int
  price         Decimal     @db.Decimal(10,2)

  orderId       String
  order         Order       @relation(fields: [orderId], references: [id])

  listingId     String
  listing       Listing     @relation(fields: [listingId], references: [id])

  @@unique([orderId, listingId])
}

model Payment{
  id            String      @id @default(uuid())
  amount        Decimal     @db.Decimal(10,2)
  status        PaymentStatus @default(PENDING)
  provider      String?
  reference     String?     @unique
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  orderId       String      @unique
  order         Order       @relation(fields: [orderId], references: [id])
}

model Review {
  id            String      @id @default(uuid())
  rating        Int
  comment       String?
  createdAt     DateTime    @default(now())

  reviewerId    String
  reviewer      User        @relation("Reviewer", fields: [reviewerId], references: [id])

  revieweeId    String      @unique
  reviewee      User        @relation("Reviewee", fields: [revieweeId], references: [id])

  listingId     String
  listing       Listing     @relation(fields: [listingId], references: [id])

  orderId       String      @unique
  order         Order       @relation(fields: [orderId], references: [id])

  @@index([revieweeId])
}

model Wishlist {
  id            String      @id @default(uuid())
  userId        String
  listingId     String
  createdAt     DateTime    @default(now())

  user          User         @relation(fields: [userId], references: [id])
  listing       Listing      @relation(fields: [listingId], references: [id])

  @@unique([userId, listingId])
  @@index([userId, listingId])
}

model VerificationRequest {
  id            String      @id @default(uuid())
  status        VerificationStatus @default(PENDING)
  documentUrl   String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  userId        String
  user          User        @relation(fields: [userId], references: [id])
}

model ModerationAction {
  id            String      @id @default(uuid())
  type          ModerationActionType
  reason        String?
  createdAt     DateTime    @default(now())

  listingId     String?
  listing       Listing?     @relation(fields: [listingId], references: [id])

  moderatorId   String
  moderator     User        @relation(fields: [moderatorId], references: [id])
}